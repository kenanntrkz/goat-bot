# goat — Environment Variables
# Copy this file to .env and fill in your values

# Apify API token (required for ScoutAgent lead finding)
# Get yours free at https://console.apify.com/account/integrations
APIFY_TOKEN=

# Instantly.ai API key (optional, for OutreachAgent email campaigns — Phase 2)
# Get yours at https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=
