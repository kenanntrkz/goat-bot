# goat — Environment Variables
# Copy this file to .env and fill in your values

# Apify API token (required for ScoutAgent lead finding)
# Get yours free at https://console.apify.com/account/integrations
APIFY_TOKEN=

# fal.ai API key (optional, for proposal covers and ad creatives)
# Get yours at https://fal.ai/dashboard/keys
FAL_KEY=

# Turkoz Outreach — kendi outreach sisteminiz (Instantly yerine)
# Internal API key — outreach.kenanturkoz.cloud INTERNAL_API_KEY ile eşleşmeli
OUTREACH_URL=https://outreach.kenanturkoz.cloud
OUTREACH_API_KEY=
