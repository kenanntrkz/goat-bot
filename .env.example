# goat — Environment Variables
# Copy this file to .env and fill in your values

# Apify API token (required for ScoutAgent lead finding)
# Get yours free at https://console.apify.com/account/integrations
APIFY_TOKEN=

# fal.ai API key (optional, for proposal covers and ad creatives)
# Get yours at https://fal.ai/dashboard/keys
FAL_KEY=

# Instantly.ai API key (optional, for OutreachAgent email campaigns)
# Get yours at https://app.instantly.ai/app/settings/integrations
INSTANTLY_API_KEY=
